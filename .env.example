# Required — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required only when using --push on a GitHub repo
# Needs 'repo' scope: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token

# Required only when using --push on a Gitea repo
# Generate at: https://<your-gitea-host>/user/settings/applications
GITEA_TOKEN=your_gitea_access_token
